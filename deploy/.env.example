POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

AUTH_DATABASE_URL=postgres://auth:authpass@postgres:5432/auth?sslmode=disable
AUTH_ENCRYPTION_KEY=GENERATE_BASE64_32_BYTES
AUTH_PUBLIC_URL=http://localhost:8080/auth
AUTH_COOKIE_DOMAIN=
AUTH_CORS_ALLOWED_ORIGINS=http://localhost:3000
AUTH_LOG_LEVEL=info
AUTH_INTERNAL_TOKEN=__GENERATE_BASE64_32_BYTES__
NOTIFICATION_BASE_URL=http://notification:8080
NOTIFICATION_INTERNAL_TOKEN=__GENERATE_BASE64_32_BYTES__
NOTIFICATION_ALLOW_INSECURE_HTTP=true
NOTIFICATION_QUEUE_ENCRYPTION_KEY=__GENERATE_BASE64_32_BYTES__
AUDIT_BASE_URL=http://audit:8080
AUDIT_INTERNAL_TOKEN=__GENERATE_BASE64_32_BYTES__
AUDIT_ALLOW_INSECURE_HTTP=true
AUTH_AUDIT_SPOOL_DIR=/var/spool/auth-audit
PDP_AUDIT_SPOOL_DIR=/var/spool/pdp-audit

PDP_DB_URL=postgres://pdp:pdppass@postgres:5432/pdp?sslmode=disable
PDP_LOG_LEVEL=info
PDP_ENV=development
PDP_ADMIN_TOKEN=
PDP_INTERNAL_TOKEN=
PDP_METRICS_TOKEN=
PDP_POLICY_FILE=/app/policy.json

REDIS_PASSWORD=

GATEWAY_HTTP_ADDR=:8080
AUTH_UPSTREAM=https://auth.internal
PDP_UPSTREAM=https://pdp.internal
GATEWAY_TRUSTED_CIDRS=
GATEWAY_READ_HEADER_TIMEOUT=5s
GATEWAY_READ_TIMEOUT=15s
GATEWAY_WRITE_TIMEOUT=15s
GATEWAY_IDLE_TIMEOUT=60s
GATEWAY_MAX_BODY_BYTES=1048576
GATEWAY_RATE_LIMIT_RPS=50
GATEWAY_RATE_LIMIT_BURST=100
GATEWAY_ENABLE_PDP_ADMIN=false
